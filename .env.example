# Copy to .env and fill in real values

APP_ENV=development
LOG_LEVEL=info
PORT=8000

DATABASE_URL=postgresql+asyncpg://supportops:changeme@localhost:5432/supportops

REDIS_URL=redis://localhost:6379
REDIS_TTL_DEFAULT=300

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=admin@yourcompany.com
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_WEBHOOK_SECRET=your-webhook-signing-secret

JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=["https://yourcompany.zendesk.com"]

PUSH_TAGS_TO_ZENDESK=true
PUSH_PRIORITY_TO_ZENDESK=true
PUSH_INTERNAL_NOTE=true
ENABLE_DEDUP=true

POSTGRES_USER=supportops
POSTGRES_PASSWORD=changeme
POSTGRES_DB=supportops
